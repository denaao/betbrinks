{
  "cli": {
    "version": ">= 7.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_URL": "http://192.168.1.100:3000",
        "WS_URL": "ws://192.168.1.100:3000",
        "ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_URL": "https://api-staging.betbrinks.com",
        "WS_URL": "wss://api-staging.betbrinks.com",
        "ENV": "staging"
      }
    },
    "production": {
      "env": {
        "API_URL": "https://api.betbrinks.com",
        "WS_URL": "wss://api.betbrinks.com",
        "ENV": "production"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "estefanij@gmail.com",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./play-store-key.json",
        "track": "internal"
      }
    }
  }
}
