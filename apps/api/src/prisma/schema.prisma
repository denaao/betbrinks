generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ──────────────────────────────────────────────────────────────────

model User {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  email         String?   @unique @db.VarChar(255)
  cpf           String?   @unique @db.VarChar(14)
  phone         String    @unique @db.VarChar(20)
  passwordHash  String    @map("password_hash")
  avatarUrl     String?   @map("avatar_url")
  isVerified    Boolean   @default(false) @map("is_verified")
  role          UserRole  @default(USER)
  level         Int       @default(1)
  xp            Int       @default(0)
  deviceId      String?   @map("device_id") @db.VarChar(255)
  lastLoginAt   DateTime? @map("last_login_at")
  lastBonusAt   DateTime? @map("last_bonus_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  balance       PointBalance?
  bets          Bet[]
  betSlips      BetSlip[]
  transactions  PointTransaction[]
  purchases     DiamondPurchase[]
  achievements  UserAchievement[]
  friendsA      Friendship[]     @relation("FriendA")
  friendsB      Friendship[]     @relation("FriendB")
  ownedLeagues  League[]
  leagueMemberships LeagueMember[]
  leagueBalances    LeagueBalance[]
  joinRequests      LeagueJoinRequest[]
  sentTransfers     LeagueTransaction[] @relation("SentTransfers")
  receivedTransfers LeagueTransaction[] @relation("ReceivedTransfers")
  affiliateProfiles LeagueAffiliate[]
  affiliateReferrals AffiliateReferral[] @relation("ReferredUser")

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ─── Point Balance ─────────────────────────────────────────────────────────

model PointBalance {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  points    Int      @default(0)
  diamonds  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_balances")
}

// ─── Point Transaction ─────────────────────────────────────────────────────

model PointTransaction {
  id           Int             @id @default(autoincrement())
  userId       Int             @map("user_id")
  type         TransactionType
  amount       Int             // positive = credit, negative = debit
  balanceAfter Int             @map("balance_after")
  description  String?         @db.VarChar(255)
  referenceId  String?         @map("reference_id") @db.VarChar(100) // bet_id, purchase_id, etc.
  createdAt    DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("point_transactions")
}

enum TransactionType {
  INITIAL_BONUS
  DAILY_BONUS
  BET_PLACED
  BET_WON
  BET_VOID
  DIAMOND_CONVERSION
  REFERRAL_REWARD
  RANKING_REWARD
  ACHIEVEMENT_REWARD
  ADMIN_ADJUSTMENT
}

// ─── Diamond Purchase ──────────────────────────────────────────────────────

model DiamondPurchase {
  id           Int                   @id @default(autoincrement())
  userId       Int                   @map("user_id")
  packageId    String                @map("package_id") @db.VarChar(50)
  diamonds     Int
  priceBrl     Decimal               @map("price_brl") @db.Decimal(10, 2)
  platform     String                @db.VarChar(20) // 'google_play' | 'app_store'
  storeReceipt String?               @map("store_receipt") @db.Text
  status       DiamondPurchaseStatus @default(PENDING)
  createdAt    DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("diamond_purchases")
}

enum DiamondPurchaseStatus {
  PENDING
  VERIFIED
  FAILED
  REFUNDED
}

// ─── Fixture (Match) ───────────────────────────────────────────────────────

model Fixture {
  id             Int           @id @default(autoincrement())
  apiFootballId  Int           @map("api_football_id")
  sportKey       String        @default("football") @map("sport_key") @db.VarChar(30) // football, basketball, volleyball, mma, formula1
  leagueId       Int           @map("league_id")
  leagueName     String        @map("league_name") @db.VarChar(100)
  leagueLogo     String?       @map("league_logo") @db.VarChar(500)
  homeTeam       String        @map("home_team") @db.VarChar(100)
  homeLogo       String?       @map("home_logo") @db.VarChar(500)
  awayTeam       String        @map("away_team") @db.VarChar(100)
  awayLogo       String?       @map("away_logo") @db.VarChar(500)
  startAt        DateTime      @map("start_at")
  status         FixtureStatus @default(NOT_STARTED)
  scoreHome      Int?          @map("score_home")
  scoreAway      Int?          @map("score_away")
  isSettled      Boolean       @default(false) @map("is_settled")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  markets Market[]
  bets    Bet[]

  @@unique([apiFootballId, sportKey])
  @@index([startAt, status])
  @@index([leagueId])
  @@index([sportKey, startAt])
  @@map("fixtures")
}

enum FixtureStatus {
  NOT_STARTED
  FIRST_HALF
  HALFTIME
  SECOND_HALF
  EXTRA_TIME
  PENALTIES
  FINISHED
  POSTPONED
  CANCELLED
  // Basketball / Volleyball
  QUARTER_1
  QUARTER_2
  QUARTER_3
  QUARTER_4
  OVERTIME
  BREAK
  SET_1
  SET_2
  SET_3
  SET_4
  SET_5
  // MMA
  ROUND_1
  ROUND_2
  ROUND_3
  ROUND_4
  ROUND_5
  // F1
  IN_PROGRESS
  SUSPENDED
}

// ─── Market ────────────────────────────────────────────────────────────────

model Market {
  id        Int        @id @default(autoincrement())
  fixtureId Int        @map("fixture_id")
  type      MarketType
  status    String     @default("active") @db.VarChar(20) // active, suspended, settled
  result    String?    @db.VarChar(50) // winning outcome name

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  odds    Odd[]

  @@unique([fixtureId, type])
  @@map("markets")
}

enum MarketType {
  // Football
  MATCH_WINNER
  OVER_UNDER_25
  BOTH_TEAMS_SCORE
  // Basketball
  BASKETBALL_WINNER
  BASKETBALL_SPREAD
  BASKETBALL_TOTAL
  // Volleyball
  VOLLEYBALL_WINNER
  VOLLEYBALL_TOTAL_SETS
  VOLLEYBALL_HANDICAP
  // MMA
  MMA_FIGHT_WINNER
  MMA_METHOD_OF_VICTORY
  MMA_TOTAL_ROUNDS
  // Formula 1
  F1_RACE_WINNER
  F1_PODIUM_FINISH
  F1_FASTEST_LAP
}

// ─── Odd ───────────────────────────────────────────────────────────────────

model Odd {
  id       Int     @id @default(autoincrement())
  marketId Int     @map("market_id")
  name     String  @db.VarChar(50) // Home, Draw, Away, Over, Under, Yes, No
  value    Decimal @db.Decimal(6, 2) // e.g., 2.45

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  bets   Bet[]

  @@unique([marketId, name])
  @@map("odds")
}

// ─── Bet Slip (Bilhete) ───────────────────────────────────────────────────

model BetSlip {
  id              Int           @id @default(autoincrement())
  userId          Int           @map("user_id")
  leagueId        Int?          @map("league_id")
  amount          Int           // total points wagered on the slip
  combinedOdd     Decimal       @map("combined_odd") @db.Decimal(10, 2)
  potentialReturn Int           @map("potential_return")
  status          BetStatus     @default(PENDING)
  settledAt       DateTime?     @map("settled_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League?  @relation(fields: [leagueId], references: [id])
  legs   Bet[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("bet_slips")
}

// ─── Bet (Leg of a Slip) ──────────────────────────────────────────────────

model Bet {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  betSlipId       Int?      @map("bet_slip_id")
  fixtureId       Int       @map("fixture_id")
  oddId           Int       @map("odd_id")
  amount          Int       // points wagered
  oddValue        Decimal   @map("odd_value") @db.Decimal(6, 2) // odd at time of placement
  potentialReturn Int       @map("potential_return")
  status          BetStatus @default(PENDING)
  settledAt       DateTime? @map("settled_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  betSlip BetSlip? @relation(fields: [betSlipId], references: [id], onDelete: Cascade)
  fixture Fixture  @relation(fields: [fixtureId], references: [id])
  odd     Odd      @relation(fields: [oddId], references: [id])

  @@index([userId, status])
  @@index([fixtureId, status])
  @@index([userId, createdAt])
  @@index([betSlipId])
  @@map("bets")
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
  CASHOUT
}

// ─── Achievement ───────────────────────────────────────────────────────────

model Achievement {
  id          Int    @id @default(autoincrement())
  key         String @unique @db.VarChar(50) // 'first_bet', 'lucky_3', 'faithful_7'
  name        String @db.VarChar(100)
  description String @db.VarChar(255)
  xpReward    Int    @default(50) @map("xp_reward")
  pointReward Int    @default(0) @map("point_reward")
  iconUrl     String? @map("icon_url") @db.VarChar(500)

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  achievementId Int      @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ─── Social ────────────────────────────────────────────────────────────────

model Friendship {
  id        Int              @id @default(autoincrement())
  userIdA   Int              @map("user_id_a")
  userIdB   Int              @map("user_id_b")
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now()) @map("created_at")

  userA User @relation("FriendA", fields: [userIdA], references: [id], onDelete: Cascade)
  userB User @relation("FriendB", fields: [userIdB], references: [id], onDelete: Cascade)

  @@unique([userIdA, userIdB])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// ─── League (Private) ──────────────────────────────────────────────────────

model League {
  id              Int           @id @default(autoincrement())
  ownerId         Int?          @map("owner_id")
  name            String        @db.VarChar(50)
  inviteCode      String        @unique @map("invite_code") @db.VarChar(10)
  isOfficial      Boolean       @default(false) @map("is_official")
  stars           Int           @default(0)  // 0-5 estrelas, define limites de membros e gestores
  starsExpiresAt  DateTime?     @map("stars_expires_at") // quando o nível expira (30 dias após upgrade)
  cashbox         Int           @default(0)  // saldo atual do caixa da liga (em pontos/fichas)
  cashboxInitial  Int           @default(0)  @map("cashbox_initial") // valor inicial depositado pelo owner
  cashboxMinAlert Int           @default(100) @map("cashbox_min_alert") // limite mínimo para alerta ao owner
  isOpen          Boolean       @default(true) @map("is_open") // liga aceita apostas? (false = caixa baixo)
  autoApprove     Boolean       @default(false) @map("auto_approve") // auto-aprovar entrada de membros
  createdAt       DateTime      @default(now()) @map("created_at")

  owner        User?             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members      LeagueMember[]
  balances     LeagueBalance[]
  joinRequests LeagueJoinRequest[]
  transactions LeagueTransaction[]
  betSlips     BetSlip[]
  cashboxLogs  CashboxLog[]
  affiliates   LeagueAffiliate[]
  affiliateCommissions AffiliateCommission[]

  @@map("leagues")
}

model CashboxLog {
  id          Int      @id @default(autoincrement())
  leagueId    Int      @map("league_id")
  type        CashboxLogType
  amount      Int      // valor movimentado (positivo = entrada, negativo = saída)
  balanceAfter Int     @map("balance_after") // saldo do caixa após a operação
  betSlipId   Int?     @map("bet_slip_id") // referência à aposta, se aplicável
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  league  League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId, createdAt])
  @@map("cashbox_logs")
}

enum CashboxLogType {
  DEPOSIT        // owner deposita diamantes → fichas no caixa
  BET_LOST       // jogador perdeu aposta → caixa recebe (valor - 10% taxa)
  BET_WON        // jogador ganhou aposta → caixa paga o prêmio
  PLATFORM_FEE   // 10% taxa da plataforma
  WITHDRAWAL     // owner retira do caixa
}

model LeagueMember {
  id       Int            @id @default(autoincrement())
  leagueId Int            @map("league_id")
  userId   Int            @map("user_id")
  role     LeagueMemberRole @default(MEMBER)
  status   LeagueMemberStatus @default(ACTIVE)
  joinedAt DateTime       @default(now()) @map("joined_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@map("league_members")
}

enum LeagueMemberRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

enum LeagueMemberStatus {
  ACTIVE
  SUSPENDED
  LEFT
}

model LeagueBalance {
  id        Int      @id @default(autoincrement())
  leagueId  Int      @map("league_id")
  userId    Int      @map("user_id")
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@map("league_balances")
}

model LeagueJoinRequest {
  id          Int               @id @default(autoincrement())
  leagueId    Int               @map("league_id")
  userId      Int               @map("user_id")
  status      JoinRequestStatus @default(PENDING)
  requestedAt DateTime          @default(now()) @map("requested_at")
  decidedAt   DateTime?         @map("decided_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@map("league_join_requests")
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeagueTransaction {
  id          Int      @id @default(autoincrement())
  leagueId    Int      @map("league_id")
  fromUserId  Int?     @map("from_user_id")
  toUserId    Int      @map("to_user_id")
  amount      Int
  type        String   @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  fromUser User?  @relation("SentTransfers", fields: [fromUserId], references: [id])
  toUser   User   @relation("ReceivedTransfers", fields: [toUserId], references: [id])

  @@index([leagueId, createdAt])
  @@index([toUserId, leagueId])
  @@map("league_transactions")
}

// ─── Affiliate System ──────────────────────────────────────────────────────

model LeagueAffiliate {
  id              Int       @id @default(autoincrement())
  leagueId        Int       @map("league_id")
  userId          Int       @map("user_id")
  parentId        Int?      @map("parent_id") // null = top-level affiliate, set = sub-affiliate
  affiliateCode   String    @unique @map("affiliate_code") @db.VarChar(12)
  revenueSharePct Int       @default(0) @map("revenue_share_pct") // 0-100%
  creditLimit     Int       @default(0) @map("credit_limit") // max fichas que pode enviar do caixa (0 = sem limite)
  creditUsed      Int       @default(0) @map("credit_used") // fichas já enviadas (reseta manual ou por período)
  passwordHash    String    @map("password_hash") // login for affiliate backoffice
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  league    League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    LeagueAffiliate? @relation("AffiliateTree", fields: [parentId], references: [id])
  children  LeagueAffiliate[] @relation("AffiliateTree")
  referrals AffiliateReferral[]
  commissions AffiliateCommission[]

  @@unique([leagueId, userId])
  @@index([affiliateCode])
  @@map("league_affiliates")
}

model AffiliateReferral {
  id            Int      @id @default(autoincrement())
  affiliateId   Int      @map("affiliate_id")
  userId        Int      @map("user_id") // the referred player
  joinedAt      DateTime @default(now()) @map("joined_at")

  affiliate LeagueAffiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  user      User            @relation("ReferredUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([affiliateId, userId])
  @@map("affiliate_referrals")
}

model AffiliateCommission {
  id            Int      @id @default(autoincrement())
  affiliateId   Int      @map("affiliate_id")
  leagueId      Int      @map("league_id")
  betSlipId     Int?     @map("bet_slip_id")
  referralUserId Int     @map("referral_user_id") // the player who lost the bet
  betAmount     Int      @map("bet_amount") // amount the player bet
  leagueProfit  Int      @map("league_profit") // how much the league earned (bet lost)
  commissionPct Int      @map("commission_pct") // % applied at the time
  commissionAmt Int      @map("commission_amt") // actual amount earned by this affiliate
  level         Int      @default(1) // 1 = direct affiliate, 2 = parent of sub-affiliate
  createdAt     DateTime @default(now()) @map("created_at")

  affiliate LeagueAffiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  league    League          @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([affiliateId, createdAt])
  @@index([leagueId, createdAt])
  @@map("affiliate_commissions")
}

// ─── Admin / Audit ─────────────────────────────────────────────────────────

model AdminUser {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  name         String    @db.VarChar(100)
  role         AdminRole @default(ANALYST)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  auditLogs AuditLog[]

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  FINANCIAL_MANAGER
  CRM_MANAGER
  ANALYST
  MODERATOR
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  adminUserId Int      @map("admin_user_id")
  action      String   @db.VarChar(100) // 'user.block', 'config.update', etc.
  targetType  String?  @map("target_type") @db.VarChar(50) // 'user', 'config', etc.
  targetId    String?  @map("target_id") @db.VarChar(50)
  details     String?  @db.Text // JSON details
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ─── Sport / Modality ─────────────────────────────────────────────────

model Sport {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(80)
  key       String   @unique @db.VarChar(30) // football, basketball, volleyball, mma, formula1
  apiHost   String   @default("") @map("api_host") @db.VarChar(200) // e.g. v3.football.api-sports.io
  icon      String?  @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  leagues ActiveLeague[]

  @@map("sports")
}

// ─── Active League ────────────────────────────────────────────────────

model ActiveLeague {
  id             Int      @id @default(autoincrement())
  apiFootballId  Int      @map("api_football_id")
  name           String   @db.VarChar(150)
  country        String   @db.VarChar(100)
  logo           String?  @db.VarChar(500)
  isActive       Boolean  @default(true) @map("is_active")
  sportId        Int?     @map("sport_id")
  createdAt      DateTime @default(now()) @map("created_at")

  sport Sport? @relation(fields: [sportId], references: [id])

  @@unique([apiFootballId, sportId])
  @@map("active_leagues")
}

// ─── System Config ─────────────────────────────────────────────────────────

model SystemConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(100)
  value String @db.Text
  type  String @default("string") @db.VarChar(20) // string, number, boolean, json

  @@map("system_configs")
}
