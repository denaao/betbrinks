# ─── BetBrinks API — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL via Neon/Supabase) ────────────────────────────────
# Generate a new password: openssl rand -base64 32
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ─── Redis (Upstash/ElastiCache) ───────────────────────────────────────────
# Regenerate token in Upstash dashboard after any suspected leak
REDIS_URL=rediss://default:TOKEN@HOST:6379

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_at_least_64_random_bytes
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=CHANGE_ME_use_different_64_random_bytes
JWT_REFRESH_EXPIRATION=7d

# ─── API-Football ───────────────────────────────────────────────────────────
# Get your key at: https://www.api-football.com/
API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
# Development: http://localhost:3001,http://localhost:3000
# Production:  https://admin.betbrincadeira.com,https://betbrincadeira.com
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ─── SSL (production only) ─────────────────────────────────────────────────
# SSL_CERT_PATH=/etc/letsencrypt/live/api.betbrincadeira.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/api.betbrincadeira.com/privkey.pem
