# ─── betbrinks Environment Variables ────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
# Se usando Docker Compose, use os valores abaixo:
DATABASE_URL=postgresql://betbrinks:betbrinks_dev_2026@localhost:5432/betbrinks

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────────────────
# Gere secrets aleatorios com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRATION=7d

# ─── API-Football ───────────────────────────────────────────────────────────
# Cadastre-se em https://www.api-football.com/ para obter sua chave
API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ─── SMS (Twilio - para verificacao de telefone) ────────────────────────────
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ─── Firebase (Push Notifications) ─────────────────────────────────────────
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_PRIVATE_KEY=your_private_key
# FIREBASE_CLIENT_EMAIL=your_client_email
